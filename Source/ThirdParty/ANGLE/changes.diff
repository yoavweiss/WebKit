+                            "context = %d, framebuffer = %u, map = 0x%016" PRIxPTR "", CID(context),
+                            framebuffer, (uintptr_t)map));
+
+    if (ANGLE_LIKELY(context != nullptr))
+    {
+        SCOPED_SHARE_CONTEXT_LOCK(context);
+        bool isCallValid = context->skipValidation();
+        if (!isCallValid)
