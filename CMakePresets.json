            "binaryDir": "WebKitBuild/cmake-mac/DebugO3",
            "cacheVariables": {
                "CMAKE_C_FLAGS_DEBUG": {
                    "type": "STRING",
                    "value": "-g -O3"
                },
                "CMAKE_CXX_FLAGS_DEBUG": {
                    "type": "STRING",
                    "value": "-g -O3"
                },
                "CMAKE_OBJC_FLAGS_DEBUG": {
                    "type": "STRING",
                    "value": "-g -O3"
                },
                "CMAKE_OBJCXX_FLAGS_DEBUG": {
                    "type": "STRING",
                    "value": "-g -O3"
                }
            }
