                    "type": "STRING",
                    "value": "-O3 -g -DNDEBUG"
                },
                "CMAKE_OBJC_FLAGS_RELWITHDEBINFO": {
                    "type": "STRING",
                    "value": "-O3 -g -DNDEBUG"
                },
                "CMAKE_OBJCXX_FLAGS_RELWITHDEBINFO": {
                    "type": "STRING",
                    "value": "-O3 -g -DNDEBUG"
                }
