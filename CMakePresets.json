        },
        {
            "name": "mac-tsan",
            "displayName": "macOS TSan (ThreadSanitizer, RelWithDebInfo, ccache)",
            "inherits": ["mac", "dev"],
            "binaryDir": "WebKitBuild/cmake-mac/TSan",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": {
                    "type": "STRING",
                    "value": "RelWithDebInfo"
                },
                "ENABLE_SANITIZERS": {
                    "type": "STRING",
                    "value": "thread"
                },
                "USE_SYSTEM_MALLOC": {
                    "type": "BOOL",
                    "value": "ON"
                },
                "ENABLE_EXPERIMENTAL_FEATURES": {
                    "type": "BOOL",
                    "value": "OFF"
                }
            }
